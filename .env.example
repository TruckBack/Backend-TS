APP_NAME=TruckBack
APP_ENV=development
DEBUG=false
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

SECRET_KEY=change-me-please-use-a-long-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
JWT_ALGORITHM=HS256

CORS_ORIGINS=

